# Backend API URL
VITE_API_URL=http://localhost:3001/api/v1

# WebSocket URL
VITE_WS_URL=ws://localhost:3001/ws

# Environment
VITE_NODE_ENV=development

# Feature flags
VITE_ENABLE_DEBUG=false

# ============================================================================
# Agent Pipeline Configuration (Phase 6)
# ============================================================================

# Enable agent pipeline feature
VITE_ENABLE_AGENT_PIPELINE=true

# Agent pipeline polling interval (ms)
VITE_PIPELINE_POLL_INTERVAL=2000

# Show detailed agent reasoning
VITE_SHOW_AGENT_DETAILS=true
