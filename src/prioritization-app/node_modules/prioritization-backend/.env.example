# Server Configuration
PORT=3001
HOST=localhost

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=debug

# API Configuration
API_PREFIX=/api

# ============================================================================
# Agent Pipeline Configuration (Phase 6)
# ============================================================================

# MCP Server URL (optional - uses local simulation if not set)
# CLEAR_THOUGHT_MCP_URL=http://localhost:8080

# Agent Pipeline Settings
AGENT_PIPELINE_TIMEOUT=60000
AGENT_PIPELINE_STOP_ON_ERROR=true

# WebSocket Configuration
WS_ENABLED=true
WS_HEARTBEAT_INTERVAL=30000
